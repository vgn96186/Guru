# Copy this file to .env and fill in your keys.
# Restart the app after changing: npx expo start --clear
#

# DeepSeek API
EXPO_PUBLIC_BUNDLED_DEEPSEEK_KEY=

# Groq API key (Fallback engine)
EXPO_PUBLIC_BUNDLED_GROQ_KEY=

# OpenRouter API (Fallback engine)
EXPO_PUBLIC_BUNDLED_OPENROUTER_KEY=

# Google AI (Gemini) keys
EXPO_PUBLIC_BUNDLED_GEMINI_KEY=
EXPO_PUBLIC_BUNDLED_GEMINI_FALLBACK_KEY=

# Cloudflare Workers AI
EXPO_PUBLIC_BUNDLED_CF_ACCOUNT_ID=
EXPO_PUBLIC_BUNDLED_CF_API_TOKEN=

# Hugging Face token (Speech-to-Text fallback)
EXPO_PUBLIC_BUNDLED_HF_TOKEN=

# GitHub Models (models.github.ai, OpenAI-compatible chat) — optional bundled default
EXPO_PUBLIC_BUNDLED_GITHUB_MODELS_PAT=

# GitLab Duo OAuth (Settings → GITLAB DUO) — optional if you paste Application ID in the app
# Redirect URI on GitLab must be: guru-study://oauth/gitlab
# Scopes: read_user, api  (api is required for /ai/third_party_agents/direct_access)
EXPO_PUBLIC_GITLAB_CLIENT_ID=
# Optional: self-managed GitLab (default https://gitlab.com)
# EXPO_PUBLIC_GITLAB_INSTANCE_URL=https://gitlab.com

# Google Sign-In (for Google Drive backup sync between devices)
# Create at: Google Cloud Console → APIs & Services → Credentials
# Type: Web application (NOT Android) — the Android client is auto-created by the plugin
# Enable "Google Drive API" in APIs & Services → Enabled APIs
# Set this once locally; Guru's start/build scripts bundle it into dev builds automatically.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
