# Copy this file to .env and fill in your keys.
# Restart the app after changing: npx expo start --clear
#
# Groq API key — used for Guru chat, transcription, and AI content when no key is set in Settings.
# Get a free key at https://console.groq.com
EXPO_PUBLIC_BUNDLED_GROQ_KEY=

# Hugging Face token — used for bundled transcription fallback when no token is set in Settings.
# Create one at https://huggingface.co/settings/tokens
EXPO_PUBLIC_BUNDLED_HF_TOKEN=
