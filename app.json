{
  "expo": {
    "name": "Guru",
    "slug": "guru-study",
    "scheme": "guru-study",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/9bd98d16-0bbc-4416-8f97-a5ac65e0dc56",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.gurustudy"
    },
    "android": {
      "edgeToEdgeEnabled": false,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0F14"
      },
      "package": "com.anonymous.gurustudy",
      "usesCleartextTraffic": true,
      "androidStatusBar": {
        "barStyle": "light-content",
        "backgroundColor": "#000000",
        "translucent": false
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-media-library",
      "expo-notifications",
      "@sentry/react-native",
      "./modules/app-launcher/withAppLauncher",
      "expo-build-properties",
      "expo-font",
      "@config-plugins/detox",
      "@react-native-google-signin/google-signin"
    ],
    "developmentClient": {
      "silentLaunch": true
    },
    "extra": {
      "eas": {
        "projectId": "9bd98d16-0bbc-4416-8f97-a5ac65e0dc56"
      }
    },
    "owner": "vgn9618"
  }
}
