        "gemini-3-flash-preview": { "name": "Gemini 3 Flash" }
      }
    },
    "pollinations": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Pollinations Pro",
      "options": {
        "baseURL": "http://localhost:8083/v1",
        "apiKey": "ignored"
      },
      "models": {
        "openai-large": { "name": "OpenAI Large" },
        "claude-large": { "name": "Claude Large" }
      }
    },
    "ollama_cloud": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama Cloud",
      "options": {
        "baseURL": "https://api.ollama.ai/v1",
        "apiKey": "000ef6a13b4c428e96c697a64b28fc5f.kcR6EoqYovecjxPGWh2WAAMe"
      },
      "models": {
        "llama-3.2-3b": { "name": "Llama 3.2 3B" },
