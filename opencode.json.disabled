      }
    },
    "nvidia": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "NVIDIA NIM",
      "options": {
        "baseURL": "https://integrate.api.nvidia.com/v1",
        "apiKey": "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"
      },
      "models": {
        "minimaxai/minimax-m2.7": { "name": "Minimax M2.7" }
      }
    },
    "mistral": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Mistral (Codestral)",
      "options": {
        "baseURL": "https://codestral.mistral.ai/v1",
        "apiKey": "fugVV7SlAlxgiNSvw1AWEQafQ6XdgHnN"
      },
      "models": {
        "codestral-latest": { "name": "Codestral Latest" }
      }
