{
  "name": "neet_study",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "generate:bundled-env": "node ./scripts/generate-bundled-env.js",
    "start": "npm run generate:bundled-env && cross-env NODE_ENV=development expo start",
    "start:fresh": "npm run generate:bundled-env && cross-env NODE_ENV=development expo start --clear",
    "android:metro": "npm run generate:bundled-env && cross-env NODE_ENV=development expo start --dev-client --localhost --port 8081 -c",
    "android:open": "node ./scripts/open-android-dev-client.js",
    "start:tee": "npm run generate:bundled-env && cross-env NODE_ENV=development expo start --clear 2>&1 | tee metro.log",
    "dev:metro": "bash ./scripts/start-metro-logs.sh",
    "stop:metro": "bash ./scripts/stop-metro.sh",
    "adb:reverse": "node ./scripts/adb-reverse.js",
    "logs:android": "adb logcat '*:S' 'ReactNative:V' 'ReactNativeJS:V' 'AndroidRuntime:E'",
    "android": "npm run generate:bundled-env && cross-env NODE_ENV=development node ./scripts/run-android-dev.js",
    "android:dev": "node ./scripts/android-dev.js",
    "android:apk:device": "npm run generate:bundled-env && cd android && NODE_BINARY=\"${NODE_BINARY:-$(command -v node)}\" ./gradlew assembleDebug --console=plain --no-daemon -PreactNativeArchitectures=arm64-v8a",
    "android:apk:release:device": "npm run generate:bundled-env && cd android && NODE_BINARY=\"${NODE_BINARY:-$(command -v node)}\" ./gradlew assembleRelease --console=plain --no-daemon -PreactNativeArchitectures=arm64-v8a",
    "android:apk:emu": "npm run generate:bundled-env && cd android && NODE_BINARY=\"${NODE_BINARY:-$(command -v node)}\" ./gradlew assembleDebug --console=plain --no-daemon -PreactNativeArchitectures=x86_64",
    "ios": "npm run generate:bundled-env && cross-env NODE_ENV=development expo run:ios",
    "web": "npm run generate:bundled-env && cross-env NODE_ENV=development expo start --web",
    "prepare": "node ./node_modules/husky/bin.js && find .husky -type f | xargs sed -i 's|/data/data/com.termux/files/usr/glibc/bin/sh|/data/data/com.termux/files/usr/bin/sh|g' 2>/dev/null; true",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"modules/**/*.{ts,tsx}\" scripts/generate-bundled-env.js App.tsx index.ts",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" \"modules/**/*.{ts,tsx}\" scripts/generate-bundled-env.js App.tsx index.ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run test:unit",
    "test:unit": "jest --runInBand --config jest.unit.config.js",
    "test:unit:coverage": "jest --runInBand --config jest.unit.config.js --coverage",
    "test:unit:coverage:logic": "jest --runInBand --config jest.unit.logic.config.js --coverage",
    "verify": "npm run typecheck && npm run lint && npm run test:unit",
    "verify:coverage": "npm run typecheck && npm run lint && npm run test:unit:coverage",
    "verify:ci": "npm run lint && npm run test:unit && npm run test:unit:coverage:logic",
    "verify:strict": "npm run typecheck && npm run lint && npm run test:unit && npm run test:unit:coverage:logic",
    "detox:test:critical": "ANDROID_SDK_ROOT=${ANDROID_SDK_ROOT:-$ANDROID_HOME} npx detox test -c android.emu.debug -- e2e/critical-path.test.ts",
    "repo-map": "node scripts/generate-repo-map.js",
    "detox:build:android:phone:debug": "ANDROID_SDK_ROOT=${ANDROID_SDK_ROOT:-/Users/vishnugnair/Library/Android/sdk} npx detox build -c android.phone.debug",
    "detox:test:android:phone:debug": "ANDROID_SDK_ROOT=${ANDROID_SDK_ROOT:-/Users/vishnugnair/Library/Android/sdk} npx detox test -c android.phone.debug",
    "detox:build:android:emu:debug": "ANDROID_SDK_ROOT=${ANDROID_SDK_ROOT:-/Users/vishnugnair/Library/Android/sdk} npx detox build -c android.emu.debug",
    "detox:test:android:emu:debug": "ANDROID_SDK_ROOT=${ANDROID_SDK_ROOT:-/Users/vishnugnair/Library/Android/sdk} npx detox test -c android.emu.debug",
    "detox:build:android:emu:release": "ANDROID_SDK_ROOT=${ANDROID_SDK_ROOT:-/Users/vishnugnair/Library/Android/sdk} npx detox build -c android.emu.release",
    "detox:test:android:emu:release": "ANDROID_SDK_ROOT=${ANDROID_SDK_ROOT:-/Users/vishnugnair/Library/Android/sdk} npx detox test -c android.emu.release",
    "detox:build:android:genymotion": "npm run detox:build:android:emu:debug",
    "detox:test:android:genymotion": "ANDROID_SDK_ROOT=${ANDROID_SDK_ROOT:-$ANDROID_HOME} bash scripts/detox-with-connected-device.sh npx detox test -c android.genymotion",
    "detox:test:critical:genymotion": "ANDROID_SDK_ROOT=${ANDROID_SDK_ROOT:-$ANDROID_HOME} bash scripts/detox-with-connected-device.sh npx detox test -c android.genymotion -- e2e/critical-path.test.ts",
    "detox:build:android:genymotion:dev": "ANDROID_SDK_ROOT=${ANDROID_SDK_ROOT:-$ANDROID_HOME} npx detox build -c android.genymotion.dev",
    "detox:test:android:genymotion:dev": "ANDROID_SDK_ROOT=${ANDROID_SDK_ROOT:-$ANDROID_HOME} bash scripts/detox-with-connected-device.sh npx detox test -c android.genymotion.dev",
    "detox:test:critical:genymotion:dev": "ANDROID_SDK_ROOT=${ANDROID_SDK_ROOT:-$ANDROID_HOME} bash scripts/detox-with-connected-device.sh npx detox test -c android.genymotion.dev -- e2e/critical-path.test.ts"
  },
  "dependencies": {
