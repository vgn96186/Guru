{
  "name": "neet_study",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:fresh": "expo start --clear",
    "android": "expo run:android",
    "android:dev": "bash ./scripts/android-dev.sh",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prepare": "node ./node_modules/husky/bin.js && find .husky -type f | xargs sed -i 's|/data/data/com.termux/files/usr/glibc/bin/sh|/data/data/com.termux/files/usr/bin/sh|g' 2>/dev/null; true",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"modules/**/*.{ts,tsx}\" App.tsx index.ts",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" \"modules/**/*.{ts,tsx}\" App.tsx index.ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run test:unit",
    "test:unit": "jest --config jest.unit.config.js",
    "test:unit:coverage": "jest --config jest.unit.config.js --coverage",
    "test:unit:coverage:logic": "jest --config jest.unit.logic.config.js --coverage",
    "verify": "npm run typecheck && npm run lint && npm run test:unit",
    "verify:coverage": "npm run typecheck && npm run lint && npm run test:unit:coverage",
    "verify:ci": "npm run lint && npm run test:unit && npm run test:unit:coverage:logic",
    "verify:strict": "npm run typecheck && npm run lint && npm run test:unit && npm run test:unit:coverage:logic",
    "detox:test:critical": "ANDROID_SDK_ROOT=${ANDROID_SDK_ROOT:-$ANDROID_HOME} npx detox test -c android.emu.debug -- e2e/starter.test.ts e2e/home.test.ts e2e/tab-navigation.test.ts",
    "repo-map": "node scripts/generate-repo-map.js",
    "detox:build:android:phone:debug": "ANDROID_SDK_ROOT=${ANDROID_SDK_ROOT:-/Users/vishnugnair/Library/Android/sdk} npx detox build -c android.phone.debug",
    "detox:test:android:phone:debug": "ANDROID_SDK_ROOT=${ANDROID_SDK_ROOT:-/Users/vishnugnair/Library/Android/sdk} npx detox test -c android.phone.debug",
    "detox:build:android:emu:debug": "ANDROID_SDK_ROOT=${ANDROID_SDK_ROOT:-/Users/vishnugnair/Library/Android/sdk} npx detox build -c android.emu.debug",
    "detox:test:android:emu:debug": "ANDROID_SDK_ROOT=${ANDROID_SDK_ROOT:-/Users/vishnugnair/Library/Android/sdk} npx detox test -c android.emu.debug",
    "detox:build:android:emu:release": "ANDROID_SDK_ROOT=${ANDROID_SDK_ROOT:-/Users/vishnugnair/Library/Android/sdk} npx detox build -c android.emu.release",
    "detox:test:android:emu:release": "ANDROID_SDK_ROOT=${ANDROID_SDK_ROOT:-/Users/vishnugnair/Library/Android/sdk} npx detox test -c android.emu.release"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@fugood/react-native-audio-pcm-stream": "^1.1.4",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-clipboard/clipboard": "^1.16.3",
    "@react-native-community/cli-server-api": "^20.1.1",
    "@react-native-community/datetimepicker": "^8.4.4",
    "@react-navigation/bottom-tabs": "^7.14.0",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.13.0",
    "app-launcher": "file:modules/app-launcher",
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
    "expo-background-fetch": "~14.0.9",
    "expo-build-properties": "~1.0.10",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-keep-awake": "~15.0.8",
    "expo-notifications": "~0.32.16",
    "expo-secure-store": "~15.0.8",
    "expo-sensors": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-speech": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-task-manager": "~14.0.9",
    "llama.rn": "^0.11.3",
    "mqtt": "^5.15.0",
    "react": "19.1.0",
    "react-native": "^0.81.5",
    "react-native-chart-kit": "^6.12.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.3",
    "react-native-worklets": "0.5.1",
    "ts-fsrs": "^3.5.0",
    "whisper.rn": "^0.5.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@config-plugins/detox": "^11.0.0",
    "@eslint/js": "^10.0.1",
    "@expo/cli": "^55.0.16",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "^54.0.10",
    "detox": "^20.47.0",
    "eslint": "^10.0.3",
    "eslint-config-expo": "^55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-native": "^5.0.0",
    "expo-module-scripts": "^55.0.2",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-circus": "^30.2.0",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "react-test-renderer": "^19.1.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.57.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "node ./node_modules/eslint/bin/eslint.js --fix",
      "node ./node_modules/prettier/bin/prettier.cjs --write"
    ],
    "*.{json,md,yml,yaml}": [
      "node ./node_modules/prettier/bin/prettier.cjs --write"
    ]
  },
  "private": true
}
