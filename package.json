    "llama.rn": "^0.11.3",
    "mqtt": "^5.15.0",
    "react": "19.1.0",
    "react-hook-form": "^7.72.1",
    "react-native": "^0.81.5",
    "react-native-chart-kit": "^6.12.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-markdown-display": "^7.0.2",
    "react-native-pager-view": "6.9.1",
