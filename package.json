{
  "name": "neet_study",
  "version": "1.0.0",
  "main": "index.ts",
  "type": "commonjs",
  "scripts": {
    "postinstall": "npx patch-package",
    "generate:bundled-env": "node ./scripts/generate-bundled-env.js",
    "syllabus:split": "ts-node --transpile-only --compiler-options '{\"module\":\"commonjs\",\"rootDir\":\".\"}' scripts/syllabus/split-topics.ts",
    "syllabus:snapshot": "UPDATE_SYLLABUS_SNAPSHOT=1 jest --runInBand --config jest.unit.config.js src/constants/syllabus.unit.test.ts",
    "start": "npm run generate:bundled-env && cross-env BROWSER=none NODE_ENV=development NODE_OPTIONS=\"--loader ./scripts/fix-esm-windows.mjs --no-warnings\" expo start --dev-client --localhost --port 8081",
    "start:fresh": "npm run generate:bundled-env && cross-env BROWSER=none NODE_ENV=development NODE_OPTIONS=\"--loader ./scripts/fix-esm-windows.mjs --no-warnings\" expo start --dev-client --localhost --port 8081 --clear",
    "android:metro": "npm run generate:bundled-env && cross-env BROWSER=none NODE_ENV=development NODE_OPTIONS=\"--loader ./scripts/fix-esm-windows.mjs --no-warnings\" expo start --dev-client --localhost --port 8081",
    "android:metro:fresh": "npm run generate:bundled-env && cross-env BROWSER=none NODE_ENV=development NODE_OPTIONS=\"--loader ./scripts/fix-esm-windows.mjs --no-warnings\" expo start --dev-client --localhost --port 8081 -c",
    "android:open": "node ./scripts/open-android-dev-client.js --deeplink",
    "android:adb-install": "node ./scripts/adb-install-dev-apk.js",
    "android:screenshot": "node ./scripts/adb-screenshot.js",
    "start:tee": "npm run generate:bundled-env && cross-env BROWSER=none NODE_ENV=development NODE_OPTIONS=\"--loader ./scripts/fix-esm-windows.mjs --no-warnings\" expo start --dev-client --localhost --port 8081 --clear 2>&1 | tee metro.log",
    "dev:metro": "node ./scripts/start-metro-logs.js",
    "stop:metro": "node ./scripts/stop-metro.js",
    "dev:launcher": "node ./scripts/launcher/server.js",
    "adb:reverse": "node ./scripts/adb-reverse.js",
    "logs:android": "adb logcat '*:S' 'ReactNative:V' 'ReactNativeJS:V' 'AndroidRuntime:E'",
    "logs:guru": "node ./scripts/fetchLogs.js",
    "android": "npm run generate:bundled-env && cross-env NODE_ENV=development GURU_OPEN_MODE=deeplink node ./scripts/run-android-dev.js",
    "dev": "bash ./scripts/dev-clean.sh",
    "android:dev": "node ./scripts/android-dev.js",
    "android:apk:device": "npm run generate:bundled-env && node ./scripts/build-apk.js --abi arm64-v8a --type debug",
    "android:apk:release:device": "npm run generate:bundled-env && node ./scripts/build-apk.js --abi arm64-v8a --type release",
    "android:apk:emu": "npm run generate:bundled-env && node ./scripts/build-apk.js --abi x86_64 --type debug",
    "ios": "npm run generate:bundled-env && cross-env NODE_ENV=development expo run:ios",
    "web": "npm run generate:bundled-env && cross-env NODE_ENV=development expo start --web",
    "prepare": "node ./node_modules/husky/bin.js && node ./scripts/fix-husky.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"modules/**/*.{ts,tsx}\" scripts/generate-bundled-env.js App.tsx index.ts",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" \"modules/**/*.{ts,tsx}\" scripts/generate-bundled-env.js App.tsx index.ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:check:scoped": "prettier --check \"src/**/*.{ts,tsx}\" \"modules/**/*.{ts,tsx}\" App.tsx index.ts scripts/generate-bundled-env.js",
    "test": "npm run test:unit",
    "test:unit": "jest --runInBand --config jest.unit.config.js",
    "test:unit:coverage": "jest --runInBand --config jest.unit.config.js --coverage",
    "test:unit:coverage:logic": "jest --runInBand --config jest.unit.logic.config.js --coverage",
    "verify:patches": "node scripts/verify-patches.js",
    "verify": "npm run verify:patches && npm run typecheck && npm run lint && npm run test:unit",
    "verify:coverage": "npm run verify:patches && npm run typecheck && npm run lint && npm run test:unit:coverage",
    "verify:ci": "npm run verify:patches && npm run lint && npm run test:unit && npm run test:unit:coverage:logic",
    "verify:ci:with-format": "npm run format:check:scoped && npm run verify:ci",
    "verify:strict": "npm run verify:patches && npm run typecheck && npm run lint && npm run test:unit && npm run test:unit:coverage:logic",
    "detox:test:critical": "node ./scripts/set-android-sdk.js npx detox test -c android.emu.debug -- e2e/critical-path.test.ts",
    "repo-map": "node scripts/generate-repo-map.js",
    "detox:build:android:phone:debug": "node ./scripts/set-android-sdk.js npx detox build -c android.phone.debug",
    "detox:test:android:phone:debug": "node ./scripts/set-android-sdk.js npx detox test -c android.phone.debug",
    "detox:build:android:emu:debug": "node ./scripts/set-android-sdk.js npx detox build -c android.emu.debug",
    "detox:test:android:emu:debug": "node ./scripts/set-android-sdk.js npx detox test -c android.emu.debug",
    "detox:build:android:emu:release": "node ./scripts/set-android-sdk.js npx detox build -c android.emu.release",
    "detox:test:android:emu:release": "node ./scripts/set-android-sdk.js npx detox test -c android.emu.release",
    "detox:build:android:genymotion": "npm run detox:build:android:emu:debug",
    "detox:test:android:genymotion": "node ./scripts/set-android-sdk.js node ./scripts/detox-with-connected-device.js npx detox test -c android.genymotion",
    "detox:test:critical:genymotion": "node ./scripts/set-android-sdk.js node ./scripts/detox-with-connected-device.js npx detox test -c android.genymotion -- e2e/critical-path.test.ts",
    "detox:build:android:genymotion:dev": "node ./scripts/set-android-sdk.js npx detox build -c android.genymotion.dev",
    "detox:test:android:genymotion:dev": "node ./scripts/set-android-sdk.js node ./scripts/detox-with-connected-device.js npx detox test -c android.genymotion.dev",
    "detox:test:critical:genymotion:dev": "node ./scripts/set-android-sdk.js node ./scripts/detox-with-connected-device.js npx detox test -c android.genymotion.dev -- e2e/critical-path.test.ts"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.163",
    "@ai-sdk/ui-utils": "^1.2.11",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@fugood/react-native-audio-pcm-stream": "^1.1.4",
    "@google/genai": "^1.46.0",
    "@gorhom/bottom-sheet": "^5.2.9",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-clipboard/clipboard": "^1.16.3",
    "@react-native-community/cli-server-api": "^20.1.1",
