export async function saveLectureTranscript(params: {
  subjectId: number | null;
  note: string;
  transcript?: string;
  summary?: string;
  topics: string[];
  confidence: number;
  embedding?: number[];
  // New optional metadata fields
  recording_path?: string;
  recording_duration_seconds?: number;
  transcription_confidence?: number | null;
  processing_metrics_json?: string;
  retry_count?: number;
  last_error?: string;
}): Promise<number> {
  const db = getDb();
  
  // Extract topics as JSON
  const topicsJson = JSON.stringify(params.topics);
  
  // Insert lecture note with all metadata
  const result = await db.runAsync(
    `INSERT INTO lecture_notes (
      subject_id, note, transcript, summary, topics_json, 
      confidence, embedding, recording_path, recording_duration_seconds,
      transcription_confidence, processing_metrics_json, retry_count, last_error
    ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`,
    [
      params.subjectId,
      params.note,
      params.transcript ?? null,
      params.summary ?? null,
      topicsJson,
      params.confidence,
      params.embedding ? JSON.stringify(params.embedding) : null,
      params.recording_path ?? null,
      params.recording_duration_seconds ?? null,
      params.transcription_confidence ?? null,
      params.processing_metrics_json ?? null,
      params.retry_count ?? 0,
      params.last_error ?? null,
    ]
  );
  
  const lectureNoteId = result.lastInsertRowId as number;
  
  // Note: topic progress tracking is now handled in LectureModeScreen
  // to avoid circular dependencies and keep concerns separated
  
  return lectureNoteId;
}
