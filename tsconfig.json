{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "isolatedModules": true,
    "incremental": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    // "@/*" maps to repo root only for TypeScript; Metro/Jest do not resolve it. Prefer relative imports in app code (see AGENTS.md).
    "paths": {
      "@/*": ["*"]
    }
  },
  "include": ["App.tsx", "index.ts", "src/**/*", "modules/**/*"],
  "exclude": [
    "Floating Overlay Widget Design",
    "**/Floating Overlay Widget Design/**",
    "android",
    "ios",
    "dist",
    "coverage",
    "artifacts"
  ]
}
